<ion-header>
  <ion-toolbar class="top-toolbar">
    <div class="header-content">
      <div class="left-actions">
        <ion-buttons slot="start" style="display:inline-block; vertical-align: middle;">
          <ion-menu-button color="primary"></ion-menu-button>
        </ion-buttons>
        <div style="display: inline-block; vertical-align: middle; margin-left: 8px;">
          <h1 style="margin: 0; font-size: 1.1rem; font-weight: 600;">Centros de Custo</h1>
          <p style="margin: 0; font-size: 0.8rem; color: #666;">Gestão Hierárquica e Controle de Obras</p>
        </div>
      </div>

      <div class="right-actions">
        <ion-button fill="outline" size="small" color="medium" class="action-btn" (click)="openImportModal()">
            <ion-icon name="cloud-upload-outline" slot="start"></ion-icon> Importar
        </ion-button>
        <ion-button fill="outline" size="small" color="medium" class="action-btn" (click)="exportCSV()">
            <ion-icon name="download-outline" slot="start"></ion-icon> Exportar
        </ion-button>
        <ion-button color="primary" class="add-btn" routerLink="/financial/cost-centers/new">
          <ion-icon name="add" slot="start"></ion-icon>
          Novo Centro de Custo
        </ion-button>
      </div>
    </div>
  </ion-toolbar>

  <ion-toolbar class="filter-toolbar">
    <div class="filter-row">
      <div class="search-box" style="flex: 1">
        <div class="label-text">Pesquisar</div>
        <div class="input-wrapper">
          <input type="text" placeholder="Buscar por código, nome ou descrição..." class="clean-search" [(ngModel)]="searchQuery" (input)="processTree()" />
          <ion-icon name="search-outline"></ion-icon>
        </div>
      </div>
    </div>
  </ion-toolbar>
</ion-header>

<ion-content class="light-bg">
  <ion-refresher slot="fixed" (ionRefresh)="loadCostCenters($event)">
    <ion-refresher-content></ion-refresher-content>
  </ion-refresher>

  <div class="data-table-container">
    <div class="table-header">
      <div class="col-nome">Estrutura / Nome do Centro</div>
      <div class="col-codigo">Código</div>
      <div class="col-info">Informações</div>
      <div class="col-orcamento">Orçamento Previsto</div>
      <div class="col-actions"></div>
    </div>

    <div class="table-body">
      <div class="table-row" *ngFor="let cc of displayRows" [routerLink]="['/financial/cost-centers', cc.id]"
        style="cursor: pointer;" [style.padding-left.px]="cc.level * 24 + 16" [class.inactive-row]="!cc.ativo">
        
        <div class="col-nome">
          <!-- Expand/Collapse toggle for parent nodes -->
          <div class="toggle-button" *ngIf="cc.hasChildren" (click)="toggleNode(cc, $event)">
            <ion-icon [name]="cc.expanded ? 'chevron-down-outline' : 'chevron-forward-outline'"></ion-icon>
          </div>
          <div class="toggle-placeholder" *ngIf="!cc.hasChildren"></div>

          <!-- Specific icon depending on level and function -->
          <ion-icon [name]="cc.hasChildren ? (cc.expanded ? 'folder-open-outline' : 'folder-outline') : (cc.aceitaLancamento ? 'document-text-outline' : 'layers-outline')" 
            class="level-icon" [class.leaf-icon]="!cc.hasChildren" [style.color]="cc.cor || '#888'"></ion-icon>
          
          <div class="name-wrapper">
            <span class="desc-main">{{ cc.nome }}</span>
            <span class="tag-badge level-badge" [class]="cc.levelName.toLowerCase()">{{ cc.levelName }}</span>
          </div>
        </div>

        <div class="col-codigo desc-main">
          <code>{{ cc.codigo || 'Sem código' }}</code>
        </div>

        <div class="col-info">
          <div class="badges-row">
            <span class="tag-badge type-badge" *ngIf="cc.tipo">{{ cc.tipo }}</span>
            <span class="tag-badge category-badge" *ngIf="cc.categoriaFinanceira" [class]="cc.categoriaFinanceira.toLowerCase()">
              {{ cc.categoriaFinanceira }}
            </span>
            <span class="tag-badge tracking-badge" [class.active]="cc.aceitaLancamento">
              {{ cc.aceitaLancamento ? 'Lançamentos' : 'Agrupador' }}
            </span>
          </div>
        </div>

        <div class="col-orcamento desc-main">
          <span *ngIf="cc.orcamentoPrevisto" class="budget-value">
            {{ cc.orcamentoPrevisto | currency:'BRL':'symbol':'1.2-2' }}
          </span>
          <span *ngIf="!cc.orcamentoPrevisto" class="budget-empty">
            -
          </span>
        </div>

        <div class="col-actions">
          <ion-button fill="clear" color="medium" size="small">
            <ion-icon slot="icon-only" name="chevron-forward-outline"></ion-icon>
          </ion-button>
        </div>
      </div>

      <div class="empty-state" *ngIf="displayRows.length === 0">
        <p>Nenhum centro de custo encontrado.</p>
      </div>
    </div>
  </div>
</ion-content>