<ion-header class="ion-no-border">
    <ion-toolbar color="white">
        <ion-buttons slot="start">
            <ion-menu-button></ion-menu-button>
        </ion-buttons>
        <ion-title>Histórico</ion-title>
        <ion-buttons slot="end">
            <ion-button color="primary" fill="solid" class="new-btn" id="history-new-trigger">
                Nova <ion-icon name="chevron-down-outline" slot="end"></ion-icon>
            </ion-button>

            <ion-popover trigger="history-new-trigger" triggerAction="click" placement="bottom" mode="ios" #newPopover>
                <ng-template>
                    <ion-list lines="none" class="new-transaction-list">
                        <ion-item button (click)="addReceita()">
                            <ion-label>Receita</ion-label>
                            <ion-note slot="end" class="shortcut-badge">Alt+R</ion-note>
                        </ion-item>
                        <ion-item button (click)="addDespesa()">
                            <ion-label>Despesa</ion-label>
                            <ion-note slot="end" class="shortcut-badge">Alt+D</ion-note>
                        </ion-item>
                        <ion-item button (click)="addTransferencia()">
                            <ion-label>Transferência</ion-label>
                            <ion-note slot="end" class="shortcut-badge">Alt+T</ion-note>
                        </ion-item>
                    </ion-list>
                </ng-template>
            </ion-popover>
        </ion-buttons>
    </ion-toolbar>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="filter-group">
            <div class="filter-label">Período</div>
            <div class="period-selector">
                <ion-select [(ngModel)]="periodFilter" (ionChange)="onFilterChange()" labelPlacement="none" mode="md"
                    toggleIcon="chevron-down-outline" interface="popover">
                    <ion-select-option value="all">Todo o histórico</ion-select-option>
                    <ion-select-option value="today">Hoje</ion-select-option>
                    <ion-select-option value="week">Esta semana</ion-select-option>
                    <ion-select-option value="month">Este mês</ion-select-option>
                    <ion-select-option value="year">Este ano</ion-select-option>
                    <ion-select-option value="last30">Últimos 30 dias</ion-select-option>
                    <ion-select-option value="custom">Personalizado</ion-select-option>
                </ion-select>
            </div>
        </div>

        <div class="filter-group search-group">
            <div class="filter-label">Pesquisar no período selecionado</div>
            <div class="search-box">
                <ion-input [(ngModel)]="searchQuery" (ionInput)="onSearch()" placeholder="Pesquisar"
                    [debounce]="500"></ion-input>
                <ion-icon name="search-outline"></ion-icon>
            </div>
        </div>
    </div>
</ion-header>

<ion-content>
    <ion-refresher slot="fixed" (ionRefresh)="loadLogs($event)">
        <ion-refresher-content></ion-refresher-content>
    </ion-refresher>

    <div class="table-responsive">
        <table class="statement-table">
            <thead>
                <tr>
                    <th class="date-col">
                        Data e hora <ion-icon name="arrow-down"></ion-icon>
                    </th>
                    <th>Usuário</th>
                    <th>Ação</th>
                    <th class="text-right">Valor (R$)</th>
                </tr>
            </thead>
            <tbody>
                <tr *ngFor="let log of logs">
                    <td class="date-cell">{{ formatDate(log.data) }}</td>
                    <td class="user-cell">{{ log.usuario?.nome }}</td>
                    <td class="action-cell">{{ log.acao }}</td>
                    <td class="value-cell text-right" [class.empty]="!getValueFromLog(log)">
                        {{ getValueFromLog(log) | currency:'BRL':'symbol':'1.2-2':'pt-BR' }}
                        <span *ngIf="!getValueFromLog(log)">-</span>
                    </td>
                </tr>

                <!-- Empty State -->
                <tr *ngIf="logs.length === 0 && !loading">
                    <td colspan="4" class="empty-state-row">
                        <div class="empty-msg">
                            <ion-icon name="list-circle-outline"></ion-icon>
                            <p>Nenhum registro encontrado no histórico.</p>
                        </div>
                    </td>
                </tr>

                <!-- Loading State -->
                <tr *ngIf="loading">
                    <td colspan="4" class="loading-row">
                        <ion-spinner name="crescent"></ion-spinner>
                        <p>Carregando histórico...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</ion-content>

<ion-footer class="ion-no-border table-footer">
    <div class="pagination-container">
        <div class="limit-selector">
            <ion-select [(ngModel)]="limit" (ionChange)="onFilterChange()" mode="md" interface="popover">
                <ion-select-option [value]="10">10</ion-select-option>
                <ion-select-option [value]="25">25</ion-select-option>
                <ion-select-option [value]="50">50</ion-select-option>
            </ion-select>
            <span>Registros por página</span>
        </div>

        <div class="pagination-controls">
            <ion-button fill="clear" (click)="prevPage()" [disabled]="currentPage === 1">
                <ion-icon name="chevron-back-outline"></ion-icon> Anterior
            </ion-button>
            <div class="page-numbers">
                <ion-button *ngFor="let page of getPagesArray()" [fill]="currentPage === page ? 'solid' : 'clear'"
                    [color]="currentPage === page ? 'primary' : 'medium'" (click)="goToPage(page)">
                    {{ page }}
                </ion-button>
            </div>
            <ion-button fill="clear" (click)="nextPage()" [disabled]="currentPage === totalPages">
                Próximo <ion-icon name="chevron-forward-outline"></ion-icon>
            </ion-button>
        </div>

        <div class="goto-page">
            <span>Ir para página</span>
            <ion-input type="number" #pageInput placeholder=""></ion-input>
            <ion-button fill="outline" color="medium" (click)="goToPage(+(pageInput.value || 1))">Ok</ion-button>
        </div>
    </div>
    <div class="results-info">
        Mostrando {{ (currentPage - 1) * limit + 1 }} - {{ Math.min(currentPage * limit, totalLogs) }} de {{ totalLogs
        }} registros
    </div>
</ion-footer>