<ion-header class="ion-no-border">
    <ion-toolbar class="header-toolbar ion-hide-md-down">
        <ion-buttons slot="start">
            <ion-menu-button></ion-menu-button>
        </ion-buttons>

        <div class="header-content">
            <div class="header-title-group">
                <h1>DRE Gerencial</h1>
                <p>Demonstração do Resultado do Exercício</p>
            </div>

            <div class="month-selector">
                <div class="filter-item">
                    <span class="filter-label">REGIME</span>
                    <ion-select [(ngModel)]="filters.regime" (ionChange)="gerarDRE()" interface="popover">
                        <ion-select-option value="caixa">Caixa</ion-select-option>
                        <ion-select-option value="competencia">Competência</ion-select-option>
                    </ion-select>
                </div>
                <div class="filter-item">
                    <span class="filter-label">FREQ.</span>
                    <ion-select [(ngModel)]="filters.granularidade" (ionChange)="gerarDRE()" interface="popover">
                        <ion-select-option value="mensal">Mensal</ion-select-option>
                        <ion-select-option value="trimestral">Trimestral</ion-select-option>
                        <ion-select-option value="anual">Anual</ion-select-option>
                    </ion-select>
                </div>
                <div class="filter-item">
                    <span class="filter-label">C. CUSTO</span>
                    <ion-select [(ngModel)]="filters.centroCustoId" (ionChange)="gerarDRE()" interface="popover" placeholder="Todos">
                        <ion-select-option value="">Todos</ion-select-option>
                        <ion-select-option *ngFor="let cc of costCenters" [value]="cc.id">{{ cc.nome }}</ion-select-option>
                    </ion-select>
                </div>
                <div class="filter-item">
                    <span class="filter-label">CONTA</span>
                    <ion-select [(ngModel)]="filters.contaBancariaId" (ionChange)="gerarDRE()" interface="popover" placeholder="Todas">
                        <ion-select-option value="">Todas</ion-select-option>
                        <ion-select-option *ngFor="let acc of bankAccounts" [value]="acc.id">{{ acc.nome }}</ion-select-option>
                    </ion-select>
                </div>
            </div>

            <div class="header-actions">
                <ion-button fill="outline" class="btn-secondary" (click)="gerarDRE()">
                    <ion-icon slot="start" name="sync-outline"></ion-icon>
                    Atualizar
                </ion-button>
            </div>
        </div>
    </ion-toolbar>

    <!-- Sub-header for date range -->
    <div class="sub-header-filters ion-hide-md-down" style="background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px;">
        <div class="date-filter-group" style="display: flex; gap: 24px;">
            <div class="date-input-wrapper" style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 12px; color: var(--ion-color-medium); font-weight: 600;">DE:</span>
                <input type="date" [(ngModel)]="filters.dataInicio" (change)="gerarDRE()" style="border: 1px solid #e2e8f0; border-radius: 4px; padding: 4px 8px; font-size: 14px; background-color: white; color: #334155;">
            </div>
            <div class="date-input-wrapper" style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 12px; color: var(--ion-color-medium); font-weight: 600;">ATÉ:</span>
                <input type="date" [(ngModel)]="filters.dataFim" (change)="gerarDRE()" style="border: 1px solid #e2e8f0; border-radius: 4px; padding: 4px 8px; font-size: 14px; background-color: white; color: #334155;">
            </div>
        </div>
    </div>
</ion-header>

<ion-content class="dashboard-content">
    <div *ngIf="loading" class="loading-overlay" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;">
        <ion-spinner name="crescent"></ion-spinner>
        <p style="margin-top: 16px; color: var(--ion-color-medium);">Gerando demonstrativo...</p>
    </div>

    <div *ngIf="dreResult && !loading" class="dashboard-wrapper" style="max-width: 1400px; margin: 24px auto; padding: 0 16px;">
        
        <!-- BLOCK 1: MAIN KPI CARDS -->
        <div class="kpi-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 24px;">
            <ion-card class="kpi-card bg-neutral" style="margin: 0; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                <ion-card-content>
                    <div class="kpi-label" style="font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 8px; text-transform: uppercase;">Resultado Líquido</div>
                    <div class="kpi-value" [class.text-red]="isNegative(dreResult.totais['resultadoLiquido'].total)" [class.text-green]="!isNegative(dreResult.totais['resultadoLiquido'].total)" style="font-size: 24px; font-weight: 700;">
                        {{ dreResult.totais['resultadoLiquido'].total | currency:'BRL' }}
                    </div>
                </ion-card-content>
            </ion-card>

            <ion-card class="kpi-card bg-blue-light" style="margin: 0; border-radius: 12px; background: #eff6ff;">
                <ion-card-content>
                    <div class="kpi-label" style="font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 8px; text-transform: uppercase;">Margem Líquida</div>
                    <div class="kpi-value" style="font-size: 24px; font-weight: 700; color: #1e40af;">
                        {{ dreResult.margens['liquida'].total | number:'1.1-1' }}%
                    </div>
                </ion-card-content>
            </ion-card>

            <ion-card class="kpi-card bg-green-light" style="margin: 0; border-radius: 12px; background: #f0fdf4;">
                <ion-card-content>
                    <div class="kpi-label" style="font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 8px; text-transform: uppercase;">Receita Operacional</div>
                    <div class="kpi-value" style="font-size: 24px; font-weight: 700; color: #16a34a;">
                        {{ dreResult.totais['receitaLiquida'].total | currency:'BRL' }}
                    </div>
                </ion-card-content>
            </ion-card>
        </div>

        <!-- BLOCK 1.5: CHARTS SECTION -->
        <div class="charts-grid" style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 24px;">
            <ion-card style="margin: 0; border-radius: 12px; padding: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); background: white;">
                <canvas id="expenseChart"></canvas>
            </ion-card>
            <ion-card style="margin: 0; border-radius: 12px; padding: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); background: white;">
                <canvas id="evolutionChart"></canvas>
            </ion-card>
        </div>

        <!-- BLOCK 2: DRE TABLE -->
        <div class="section-block" style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 24px;">
            <div class="section-header" style="margin-bottom: 24px;">
                <h2 style="font-size: 18px; font-weight: 700; color: #0f172a; margin: 0;">📊 Demonstrativo Detalhado</h2>
                <p style="font-size: 14px; color: #64748b; margin: 4px 0 0 0;">Análise de performance por período</p>
            </div>

            <div class="table-container" style="width: 100%; overflow-x: auto;">
                <table class="custom-table" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="text-align: left; padding: 12px; font-size: 13px; font-weight: 600; color: #64748b; border-bottom: 2px solid #e2e8f0; position: sticky; left: 0; background: white; z-index: 2;">DESCRIÇÃO</th>
                            <th *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 12px; font-size: 13px; font-weight: 600; color: #64748b; border-bottom: 2px solid #e2e8f0; min-width: 120px;">{{ p }}</th>
                            <th style="text-align: right; padding: 12px; font-size: 13px; font-weight: 600; color: #64748b; border-bottom: 2px solid #e2e8f0; min-width: 120px; background: #f8fafc;">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- 1. RECEITAS -->
                        <tr class="group-row" style="background: #f8fafc; cursor: pointer;" (click)="toggleBlock('RECEITAS')">
                            <td class="sticky-cell" style="padding: 14px 12px; font-weight: 700; color: #0f172a; position: sticky; left: 0; background: #f8fafc; z-index: 1;">
                                <ion-icon [name]="expandedBlocks['RECEITAS'] ? 'chevron-down-outline' : 'chevron-forward-outline'" style="font-size: 16px; margin-right: 8px; vertical-align: middle;"></ion-icon>
                                1. RECEITAS BRUTAS
                            </td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 14px 12px; font-weight: 700;">{{ dreResult.totais['receitaBruta'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 14px 12px; font-weight: 700; background: #f1f5f9;">{{ dreResult.totais['receitaBruta'].total | number:'1.2-2' }}</td>
                        </tr>
                        <ng-container *ngIf="expandedBlocks['RECEITAS']">
                             <!-- Recorrentes -->
                            <tr class="sub-group-row clickable" style="background: #fafafa; cursor: pointer;" (click)="abrirDetalhes('RECEITA_RECORRENTE')">
                                <td class="indent-1" style="padding: 10px 12px 10px 32px; font-weight: 600; color: #334155; position: sticky; left: 0; background: #fafafa;">Receitas Recorrentes <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px; color: var(--ion-color-primary)"></ion-icon></td>
                                <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 10px 12px;">{{ dreResult.data['RECEITA_RECORRENTE'].periodos[p] | number:'1.2-2' }}</td>
                                <td style="text-align: right; padding: 10px 12px; font-weight: 600;">{{ dreResult.data['RECEITA_RECORRENTE'].total | number:'1.2-2' }}</td>
                            </tr>
                            <tr *ngFor="let sub of getSubcategorias('RECEITA_RECORRENTE')" class="leaf-row clickable" style="cursor: pointer;" (click)="abrirDetalhes('RECEITA_RECORRENTE', sub[0])">
                                <td class="indent-2" style="padding: 8px 12px 8px 52px; font-size: 13px; color: #64748b; position: sticky; left: 0; background: white;">{{ sub[0] }} <ion-icon name="open-outline" style="font-size: 12px; margin-left: 4px; color: var(--ion-color-primary)"></ion-icon></td>
                                <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 8px 12px; font-size: 13px;">{{ sub[1].periodos[p] | number:'1.2-2' }}</td>
                                <td style="text-align: right; padding: 8px 12px; font-size: 13px; background: #f8fafc;">{{ sub[1].total | number:'1.2-2' }}</td>
                            </tr>
                        </ng-container>

                        <!-- 1.1 DEDUCOES -->
                        <tr class="sub-group-row clickable" style="background: #fafafa; cursor: pointer;" (click)="abrirDetalhes('DEDUCOES_RECEITA')">
                            <td class="indent-1" style="padding: 10px 12px; color: #ef4444; position: sticky; left: 0; background: #fafafa;">(-) Deduções <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon></td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 10px 12px; color: #ef4444;">{{ dreResult.data['DEDUCOES_RECEITA'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 10px 12px; font-weight: 600; color: #ef4444;">{{ dreResult.data['DEDUCOES_RECEITA'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- RESULTADO INTERMEDIÁRIO: RECEITA LÍQUIDA -->
                        <tr class="summary-row" style="border-top: 1px solid #e2e8f0; border-bottom: 2px solid #e2e8f0; background: #f1f5f9;">
                            <td class="sticky-cell" style="padding: 12px; font-weight: 700; color: #1e293b; position: sticky; left: 0; background: #f1f5f9;">(=) RECEITA LÍQUIDA</td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 12px; font-weight: 700;">{{ dreResult.totais['receitaLiquida'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 12px; font-weight: 800; color: #0f172a;">{{ dreResult.totais['receitaLiquida'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- 2. CUSTOS -->
                        <tr class="group-row" style="background: #f8fafc; cursor: pointer;" (click)="abrirDetalhes('CUSTO_SERVICOS_PRESTADOS')">
                            <td class="sticky-cell" style="padding: 14px 12px; color: #f97316; font-weight: 700; position: sticky; left: 0; background: #f8fafc;">
                                (-) 2. CUSTOS (CPV/CSP) <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon>
                            </td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 14px 12px; color: #f97316;">{{ dreResult.data['CUSTO_SERVICOS_PRESTADOS'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 14px 12px; font-weight: 700; background: #f1f5f9; color: #f97316;">{{ dreResult.data['CUSTO_SERVICOS_PRESTADOS'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- LUCRO BRUTO -->
                        <tr class="summary-row" style="background: #f1f5f9;">
                            <td class="sticky-cell" style="padding: 12px; font-weight: 700; color: #1e293b; position: sticky; left: 0; background: #f1f5f9;">(=) LUCRO BRUTO</td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 12px; font-weight: 700;">{{ dreResult.totais['lucroBruto'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 12px; font-weight: 800; color: #0f172a;">{{ dreResult.totais['lucroBruto'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- 3. DESPESAS OPERACIONAIS -->
                        <tr class="group-row" style="background: #f8fafc; cursor: pointer;" (click)="toggleBlock('DESPESAS')">
                            <td class="sticky-cell" style="padding: 14px 12px; font-weight: 700; color: #0f172a; position: sticky; left: 0; background: #f8fafc;">
                                <ion-icon [name]="expandedBlocks['DESPESAS'] ? 'chevron-down-outline' : 'chevron-forward-outline'" style="font-size: 16px; margin-right: 8px; vertical-align: middle;"></ion-icon>
                                3. DESPESAS OPERACIONAIS
                            </td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 14px 12px; font-weight: 700;">
                                {{ (dreResult.data['DESPESA_ADMINISTRATIVA'].periodos[p] + dreResult.data['DESPESA_COMERCIAL'].periodos[p] + dreResult.data['DESPESA_ESTRUTURAL'].periodos[p] + dreResult.data['DESPESA_SOCIOS'].periodos[p]) | number:'1.2-2' }}
                            </td>
                            <td style="text-align: right; padding: 14px 12px; font-weight: 700; background: #f1f5f9;">
                                {{ (dreResult.data['DESPESA_ADMINISTRATIVA'].total + dreResult.data['DESPESA_COMERCIAL'].total + dreResult.data['DESPESA_ESTRUTURAL'].total + dreResult.data['DESPESA_SOCIOS'].total) | number:'1.2-2' }}
                            </td>
                        </tr>
                        <ng-container *ngIf="expandedBlocks['DESPESAS']">
                            <tr *ngFor="let cat of ['DESPESA_ADMINISTRATIVA', 'DESPESA_COMERCIAL', 'DESPESA_ESTRUTURAL', 'DESPESA_SOCIOS']" 
                                class="sub-group-row clickable" style="background: #fafafa; cursor: pointer;" (click)="abrirDetalhes(cat)">
                                <td class="indent-1" style="padding: 10px 12px 10px 32px; font-weight: 600; color: #334155; position: sticky; left: 0; background: #fafafa;">{{ cat.replace('DESPESA_', '') }} <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon></td>
                                <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 10px 12px;">{{ dreResult.data[cat].periodos[p] | number:'1.2-2' }}</td>
                                <td style="text-align: right; padding: 10px 12px; font-weight: 600;">{{ dreResult.data[cat].total | number:'1.2-2' }}</td>
                            </tr>
                        </ng-container>

                        <!-- RESULTADO ANTES DOS IMPOSTOS (LAIR) -->
                        <tr class="summary-row" style="background: #f1f5f9;">
                            <td class="sticky-cell" style="padding: 12px; font-weight: 700; color: #1e293b; position: sticky; left: 0; background: #f1f5f9;">(=) LAIR (Lucro antes de Impostos)</td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 12px; font-weight: 700;">{{ dreResult.totais['lair'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 12px; font-weight: 800; color: #0f172a;">{{ dreResult.totais['lair'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- 4. RESULTADOS FINANCEIROS -->
                        <tr class="group-row" style="background: #f8fafc; cursor: pointer;" (click)="toggleBlock('FINANCEIRO')">
                            <td class="sticky-cell" style="padding: 14px 12px; font-weight: 700; color: #0f172a; position: sticky; left: 0; background: #f8fafc;">
                                <ion-icon [name]="expandedBlocks['FINANCEIRO'] ? 'chevron-down-outline' : 'chevron-forward-outline'" style="font-size: 16px; margin-right: 8px; vertical-align: middle;"></ion-icon>
                                4. RESULTADOS FINANCEIROS
                            </td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 14px 12px; font-weight: 700;">
                                {{ (dreResult.data['RECEITA_FINANCEIRA'].periodos[p] - dreResult.data['DESPESA_FINANCEIRA'].periodos[p]) | number:'1.2-2' }}
                            </td>
                            <td style="text-align: right; padding: 14px 12px; font-weight: 700; background: #f1f5f9;">
                                {{ (dreResult.data['RECEITA_FINANCEIRA'].total - dreResult.data['DESPESA_FINANCEIRA'].total) | number:'1.2-2' }}
                            </td>
                        </tr>
                        <ng-container *ngIf="expandedBlocks['FINANCEIRO']">
                            <tr class="sub-group-row clickable" style="background: #fafafa; cursor: pointer;" (click)="abrirDetalhes('RECEITA_FINANCEIRA')">
                                <td class="indent-1" style="padding: 10px 12px 10px 32px; color: #16a34a; position: sticky; left: 0; background: #fafafa;">(+) Receitas Financeiras <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon></td>
                                <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 10px 12px; color: #16a34a;">{{ dreResult.data['RECEITA_FINANCEIRA'].periodos[p] | number:'1.2-2' }}</td>
                                <td style="text-align: right; padding: 10px 12px; font-weight: 600; color: #16a34a;">{{ dreResult.data['RECEITA_FINANCEIRA'].total | number:'1.2-2' }}</td>
                            </tr>
                            <tr class="sub-group-row clickable" style="background: #fafafa; cursor: pointer;" (click)="abrirDetalhes('DESPESA_FINANCEIRA')">
                                <td class="indent-1" style="padding: 10px 12px 10px 32px; color: #ef4444; position: sticky; left: 0; background: #fafafa;">(-) Despesas Financeiras <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon></td>
                                <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 10px 12px; color: #ef4444;">{{ dreResult.data['DESPESA_FINANCEIRA'].periodos[p] | number:'1.2-2' }}</td>
                                <td style="text-align: right; padding: 10px 12px; font-weight: 600; color: #ef4444;">{{ dreResult.data['DESPESA_FINANCEIRA'].total | number:'1.2-2' }}</td>
                            </tr>
                        </ng-container>

                        <!-- 5. IMPOSTOS SOBRE O LUCRO -->
                        <tr class="group-row clickable" style="background: #f8fafc; cursor: pointer;" (click)="abrirDetalhes('IMPOSTOS_LUCRO')">
                            <td class="sticky-cell" style="padding: 14px 12px; font-weight: 700; color: #ef4444; position: sticky; left: 0; background: #f8fafc;">
                                (-) 5. IMPOSTOS SOBRE O LUCRO <ion-icon name="open-outline" style="font-size: 14px; margin-left: 4px;"></ion-icon>
                            </td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 14px 12px; color: #ef4444;">{{ dreResult.data['IMPOSTOS_LUCRO'].periodos[p] | number:'1.2-2' }}</td>
                            <td style="text-align: right; padding: 14px 12px; font-weight: 700; background: #f1f5f9; color: #ef4444;">{{ dreResult.data['IMPOSTOS_LUCRO'].total | number:'1.2-2' }}</td>
                        </tr>

                        <!-- FINAL RESULT -->
                        <tr class="total-row" style="background: #0f172a; color: white;">
                            <td class="sticky-cell" style="padding: 16px 12px; font-weight: 700; font-size: 15px; position: sticky; left: 0; background: #0f172a;">(=) RESULTADO LÍQUIDO DO PERÍODO</td>
                            <td *ngFor="let p of dreResult.periodos" style="text-align: right; padding: 16px 12px; font-weight: 700;" [class.text-red-light]="isNegative(dreResult.totais['resultadoLiquido'].periodos[p])">
                                {{ dreResult.totais['resultadoLiquido'].periodos[p] | number:'1.2-2' }}
                            </td>
                            <td style="text-align: right; padding: 16px 12px; font-weight: 800; font-size: 16px;" [class.text-red-light]="isNegative(dreResult.totais['resultadoLiquido'].total)">
                                {{ dreResult.totais['resultadoLiquido'].total | number:'1.2-2' }}
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div *ngIf="!dreResult && !loading" class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #64748b;">
        <ion-icon name="analytics-outline" style="font-size: 64px; margin-bottom: 16px; opacity: 0.2;"></ion-icon>
        <h2 style="font-size: 18px; font-weight: 600; margin: 0;">Nenhum dado gerado</h2>
        <p style="margin: 8px 0 0 0;">Ajuste os filtros e clique em atualizar.</p>
    </div>
</ion-content>
