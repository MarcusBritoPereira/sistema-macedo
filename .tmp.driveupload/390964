<ion-header>
  <ion-toolbar>
    <ion-buttons slot="start">
      <ion-menu-button></ion-menu-button>
    </ion-buttons>
    <ion-title>Central de relatórios</ion-title>
    <ion-buttons slot="end">
      <ion-button fill="clear" (click)="reloadPageData()" [disabled]="loadingReports || loadingFilters">
        <ion-icon name="refresh-outline"></ion-icon>
      </ion-button>
    </ion-buttons>
  </ion-toolbar>
</ion-header>

<ion-content class="ion-padding">
  <section class="hero">
    <div class="hero-text">
      <h2>Relatórios mais rápidos e claros</h2>
      <p>
        1) Defina os filtros, 2) selecione os relatórios, 3) gere o pacote. Tudo em uma única tela.
      </p>
    </div>
    <div class="hero-badges">
      <ion-badge color="primary">{{ periodLabel }}</ion-badge>
      <ion-badge color="success">{{ selectedCount }} selecionado(s)</ion-badge>
      <ion-badge [color]="hasValidDateRange ? 'tertiary' : 'warning'">
        {{ hasValidDateRange ? 'Período válido' : 'Revise datas' }}
      </ion-badge>
    </div>
  </section>

  <ion-card class="filters-card">
    <ion-card-header>
      <ion-card-title>
        <ion-icon name="filter-outline"></ion-icon>
        Parâmetros do pacote
      </ion-card-title>
      <ion-card-subtitle>Todos os relatórios selecionados usarão os filtros abaixo.</ion-card-subtitle>
    </ion-card-header>
    <ion-card-content>
      <ion-grid>
        <ion-row>
          <ion-col size="12" size-md="3">
            <ion-item>
              <ion-label position="stacked">Período</ion-label>
              <ion-select [(ngModel)]="selectedPeriod" interface="popover" (ionChange)="onPeriodChange()">
                <ion-select-option value="month">Mês atual</ion-select-option>
                <ion-select-option value="quarter">Trimestre</ion-select-option>
                <ion-select-option value="year">Ano corrente</ion-select-option>
                <ion-select-option value="custom">Personalizado</ion-select-option>
              </ion-select>
            </ion-item>
          </ion-col>
          <ion-col size="12" size-md="3">
            <ion-item>
              <ion-label position="stacked">Conta bancária</ion-label>
              <ion-select [(ngModel)]="selectedAccount" interface="popover" [disabled]="loadingFilters">
                <ion-select-option value="all">Todas</ion-select-option>
                <ion-select-option *ngFor="let account of bankAccounts" [value]="account.id">
                  {{ account.nome }} ({{ account.banco }})
                </ion-select-option>
              </ion-select>
            </ion-item>
          </ion-col>
          <ion-col size="12" size-md="3">
            <ion-item>
              <ion-label position="stacked">Centro de custo</ion-label>
              <ion-select [(ngModel)]="selectedCostCenter" interface="popover" [disabled]="loadingFilters">
                <ion-select-option value="all">Todos</ion-select-option>
                <ion-select-option *ngFor="let center of costCenters" [value]="center.id">
                  {{ center.nome }}
                </ion-select-option>
              </ion-select>
            </ion-item>
          </ion-col>
          <ion-col size="12" size-md="3">
            <ion-item lines="none" class="toggle-item">
              <ion-label>Incluir provisões</ion-label>
              <ion-toggle [(ngModel)]="includeProvisional"></ion-toggle>
            </ion-item>
          </ion-col>
        </ion-row>

        <ion-row class="date-row">
          <ion-col size="12" size-md="4">
            <ion-item [disabled]="selectedPeriod !== 'custom'">
              <ion-label position="stacked">Data inicial</ion-label>
              <ion-datetime-button datetime="startDatePicker"></ion-datetime-button>
              <ion-modal keepContentsMounted="true">
                <ion-datetime id="startDatePicker" presentation="date" [(ngModel)]="startDate"></ion-datetime>
              </ion-modal>
            </ion-item>
          </ion-col>
          <ion-col size="12" size-md="4">
            <ion-item [disabled]="selectedPeriod !== 'custom'">
              <ion-label position="stacked">Data final</ion-label>
              <ion-datetime-button datetime="endDatePicker"></ion-datetime-button>
              <ion-modal keepContentsMounted="true">
                <ion-datetime id="endDatePicker" presentation="date" [(ngModel)]="endDate"></ion-datetime>
              </ion-modal>
            </ion-item>
          </ion-col>
          <ion-col size="12" size-md="4" class="actions-col">
            <ion-button expand="block" fill="outline" (click)="applyFilters()">
              <ion-icon name="checkmark-circle-outline" slot="start"></ion-icon>
              Validar filtros
            </ion-button>
            <ion-button expand="block" (click)="generateReports()" [disabled]="!canGenerate">
              <ion-icon name="sparkles-outline" slot="start"></ion-icon>
              <span *ngIf="!generating">Gerar pacote agora</span>
              <ion-spinner *ngIf="generating" name="dots"></ion-spinner>
            </ion-button>
          </ion-col>
        </ion-row>
      </ion-grid>
    </ion-card-content>
  </ion-card>

  <section class="selection-summary">
    <ion-card>
      <ion-card-content>
        <div class="summary-header">
          <div>
            <h3>Seleção atual</h3>
            <p>Escolha os relatórios desejados e gere seu pacote.</p>
          </div>
          <ion-badge color="primary">{{ selectedCount }} selecionados</ion-badge>
        </div>

        <div class="summary-actions">
          <ion-button fill="clear" size="small" (click)="selectAllFiltered()" [disabled]="loadingReports">
            Selecionar resultados da busca
          </ion-button>
          <ion-button fill="clear" size="small" (click)="clearSelection()" [disabled]="selectedCount === 0">
            Limpar seleção
          </ion-button>
        </div>

        <ion-list lines="none">
          <ion-item *ngFor="let label of selectedLabels">
            <ion-icon name="checkmark-circle-outline" slot="start" color="success"></ion-icon>
            <ion-label>{{ label }}</ion-label>
          </ion-item>
          <ion-item *ngIf="selectedLabels.length === 0">
            <ion-label color="medium">Nenhum relatório selecionado ainda.</ion-label>
          </ion-item>
        </ion-list>

        <div class="generation-result" *ngIf="lastGeneration">
          <p>
            Última geração: {{ lastGeneration.count }} relatório(s) • {{ lastGeneration.generatedAt | date:'short' }}
          </p>
          <ion-list lines="none">
            <ion-item *ngFor="let report of lastGeneration.reports" button (click)="viewReport(report)" [detail]="true">
              <ion-icon name="document-text-outline" slot="start" color="primary"></ion-icon>
              <ion-label>
                <h2>{{ report.title }}</h2>
                <p>{{ report.status === 'ready' ? 'Pronto para visualizar' : 'Processando...' }}</p>
              </ion-label>
              <ion-button fill="clear" slot="end" (click)="$event.stopPropagation(); viewReport(report)">
                <ion-icon name="eye-outline" slot="icon-only"></ion-icon>
              </ion-button>
            </ion-item>
          </ion-list>
        </div>
      </ion-card-content>
    </ion-card>
  </section>

  <section>
    <div class="section-header">
      <h3>Catálogo de relatórios</h3>
      <ion-badge color="medium">{{ filteredReports.length }} de {{ reports.length }}</ion-badge>
    </div>

    <ion-searchbar
      placeholder="Buscar por nome, categoria, tag..."
      [(ngModel)]="reportSearch"
      animated="true"
      show-clear-button="focus"
    ></ion-searchbar>

    <ion-grid>
      <ion-row>
        <ion-col size="12" *ngIf="loadingReports" class="loading-state">
          <ion-spinner name="dots"></ion-spinner>
          <p>Buscando relatórios disponíveis...</p>
        </ion-col>
        <ion-col size="12" *ngIf="!loadingReports && filteredReports.length === 0" class="loading-state">
          <p>Nenhum relatório encontrado para este filtro de busca.</p>
        </ion-col>

        <ion-col size="12" size-md="6" size-lg="4" *ngFor="let report of filteredReports">
          <ion-card class="report-card" [class.selected]="isSelected(report.id)">
            <ion-card-header>
              <div class="card-title">
                <ion-icon [name]="report.icon" class="report-icon"></ion-icon>
                <div>
                  <ion-card-title>{{ report.title }}</ion-card-title>
                  <ion-card-subtitle>{{ report.description }}</ion-card-subtitle>
                </div>
              </div>
            </ion-card-header>
            <ion-card-content>
              <div class="meta">
                <ion-chip color="primary">
                  <ion-icon name="calendar-outline"></ion-icon>
                  <ion-label>{{ report.cadence }}</ion-label>
                </ion-chip>
                <ion-chip color="tertiary">
                  <ion-icon name="analytics-outline"></ion-icon>
                  <ion-label>{{ report.category }}</ion-label>
                </ion-chip>
              </div>
              <div class="tags">
                <ion-badge *ngFor="let tag of report.tags" color="success">{{ tag }}</ion-badge>
              </div>
              <ul class="highlights">
                <li *ngFor="let item of report.highlights">{{ item }}</li>
              </ul>
              <ion-button expand="block" fill="outline" (click)="toggleReport(report.id)">
                <ion-icon [name]="isSelected(report.id) ? 'checkmark-circle-outline' : 'document-text-outline'" slot="start"></ion-icon>
                {{ isSelected(report.id) ? 'Selecionado' : 'Adicionar à seleção' }}
              </ion-button>
            </ion-card-content>
          </ion-card>
        </ion-col>
      </ion-row>
    </ion-grid>
  </section>

  <ion-modal [isOpen]="isModalOpen" (didDismiss)="closeModal()">
    <ng-template>
      <ion-header>
        <ion-toolbar>
          <ion-title>{{ viewingReport?.title }}</ion-title>
          <ion-buttons slot="end">
            <ion-button (click)="closeModal()">Fechar</ion-button>
          </ion-buttons>
        </ion-toolbar>
      </ion-header>
      <ion-content class="ion-padding">
        <app-report-viewer [data]="reportData" [title]="viewingReport?.title" [period]="periodLabel"></app-report-viewer>
      </ion-content>
    </ng-template>
  </ion-modal>
</ion-content>
