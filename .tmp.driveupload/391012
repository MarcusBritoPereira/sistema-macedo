<ion-header>
  <!-- Top Bar: Title & Primary Actions (Desktop) -->
  <ion-toolbar class="top-toolbar ion-hide-md-down">
    <div class="header-content">
      <div class="left-actions">
        <ion-buttons slot="start" style="display:inline-block; vertical-align: middle;">
          <ion-menu-button color="primary"></ion-menu-button>
        </ion-buttons>
        <div style="display: inline-block; vertical-align: middle; margin-left: 8px;">
          <h1 style="margin: 0; font-size: 1.1rem; font-weight: 600;">Categorias</h1>
          <p style="margin: 0; font-size: 0.8rem; color: #666;">Gestão de Categorias e Classificação DRE</p>
        </div>
      </div>

      <div class="right-actions">
        <ion-button fill="outline" size="small" color="medium" class="action-btn" (click)="openImportModal()">
          <ion-icon name="cloud-upload-outline" slot="start"></ion-icon> Importar
        </ion-button>
        <ion-button fill="outline" size="small" color="medium" class="action-btn" (click)="exportCSV()">
          <ion-icon name="download-outline" slot="start"></ion-icon> Exportar
        </ion-button>
        <ion-button color="primary" class="add-btn" routerLink="/financial/categories/new">
          <ion-icon name="add" slot="start"></ion-icon>
          Nova Categoria
        </ion-button>
      </div>
    </div>
  </ion-toolbar>

  <!-- Mobile Top Bar -->
  <ion-toolbar class="top-toolbar ion-hide-md-up">
    <div class="header-content" style="padding: 4px 0;">
      <div class="left-actions">
        <ion-buttons slot="start" style="display:inline-block; vertical-align: middle;">
          <ion-menu-button color="primary"></ion-menu-button>
        </ion-buttons>
        <div style="display: inline-block; vertical-align: middle; margin-left: 4px;">
          <h2 style="margin: 0; font-size: 1.05rem; font-weight: 600;">Categorias</h2>
        </div>
      </div>
      <div class="right-actions">
        <ion-button fill="clear" size="small" color="primary" routerLink="/financial/categories/new" style="margin: 0; font-weight: 700;">
          <ion-icon name="add-outline" slot="icon-only"></ion-icon>
        </ion-button>
      </div>
    </div>
  </ion-toolbar>

  <ion-toolbar class="filter-toolbar">
    <div class="filter-row">
      <div class="search-box" style="flex: 1">
        <div class="label-text">Pesquisar</div>
        <div class="input-wrapper">
          <input type="text" placeholder="Buscar por nome, tipo ou classificação..." class="clean-search" (input)="filterCategories($event)" />
          <ion-icon name="search-outline"></ion-icon>
        </div>
      </div>
    </div>
  </ion-toolbar>
</ion-header>

<ion-content class="light-bg">
  <ion-refresher slot="fixed" (ionRefresh)="loadCategories($event)">
    <ion-refresher-content></ion-refresher-content>
  </ion-refresher>

  <!-- Desktop Data Table -->
  <div class="data-table-container ion-hide-md-down">
    <div class="table-header">
      <div class="col-nome">Nome da Categoria</div>
      <div class="col-tipo">Tipo</div>
      <div class="col-classificacao">Classificação DRE</div>
      <div class="col-subcategorias">Subcategorias</div>
      <div class="col-actions"></div>
    </div>

    <div class="table-body">
      <div class="table-row" *ngFor="let category of filteredCategories" [routerLink]="['/financial/categories', category.id]"
        style="cursor: pointer;">
        
        <div class="col-nome">
          <div class="icon-box" [class.revenue]="category.tipo === 'RECEITA'" [class.expense]="category.tipo === 'DESPESA'" style="margin-right: 12px; width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px;">
            <ion-icon [name]="category.tipo === 'RECEITA' ? 'arrow-down-circle-outline' : 'arrow-up-circle-outline'"></ion-icon>
          </div>
          <span class="desc-main" style="font-weight: 600; color: #0f172a; font-size: 0.95rem;">{{ category.nome }}</span>
        </div>

        <div class="col-tipo">
          <span class="tag-badge category-badge" [class.receita]="category.tipo === 'RECEITA'" [class.despesa]="category.tipo === 'DESPESA'">
            {{ category.tipo === 'RECEITA' ? 'Receita' : 'Despesa' }}
          </span>
        </div>

        <div class="col-classificacao">
          <span class="tag-badge dre-badge" *ngIf="category.classificacao">
            {{ getDRELabel(category.classificacao) }}
          </span>
          <span class="budget-empty" *ngIf="!category.classificacao" style="color: #94a3b8;">-</span>
        </div>

        <div class="col-subcategorias desc-main" style="color: #475569; font-weight: 500;">
          {{ category.subcategorias?.length || 0 }} subcategorias
        </div>

        <div class="col-actions">
          <ion-button fill="clear" color="medium" size="small">
            <ion-icon slot="icon-only" name="chevron-forward-outline"></ion-icon>
          </ion-button>
        </div>
      </div>

      <div class="empty-state" *ngIf="filteredCategories.length === 0" style="padding: 60px 40px; text-align: center; color: #94a3b8; font-weight: 500;">
        <p>Nenhuma categoria encontrada.</p>
      </div>
    </div>
  </div>

  <!-- Mobile Card List -->
  <div class="mobile-list-container ion-hide-md-up" style="padding: 16px; display: flex; flex-direction: column; gap: 12px; padding-bottom: 80px;">
    <div class="empty-state" *ngIf="filteredCategories.length === 0" style="text-align: center; padding: 40px 20px; color: var(--ion-color-medium);">
      <ion-icon name="pricetags-outline" style="font-size: 48px; opacity: 0.5; margin-bottom: 12px;"></ion-icon>
      <p>Nenhuma categoria encontrada.</p>
    </div>
    
    <ion-card class="mobile-item-card" *ngFor="let category of filteredCategories" [routerLink]="['/financial/categories', category.id]"
      style="margin: 0; border-radius: 12px; border: 1px solid #cbd5e1; box-shadow: none;">
      <ion-card-content style="padding: 16px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div class="icon-box" [class.revenue]="category.tipo === 'RECEITA'" [class.expense]="category.tipo === 'DESPESA'" 
              style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
              <ion-icon [name]="category.tipo === 'RECEITA' ? 'arrow-down-circle-outline' : 'arrow-up-circle-outline'"></ion-icon>
            </div>
            <div>
              <h3 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #0f172a;">{{ category.nome }}</h3>
              <p style="margin: 2px 0 0 0; font-size: 0.8rem; color: #64748b;">
                {{ category.subcategorias?.length || 0 }} subcategorias
              </p>
            </div>
          </div>
          <ion-icon name="chevron-forward-outline" style="color: #94a3b8; font-size: 1.2rem;"></ion-icon>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-top: 8px;">
          <span class="tag-badge category-badge" [class.receita]="category.tipo === 'RECEITA'" [class.despesa]="category.tipo === 'DESPESA'">
            {{ category.tipo === 'RECEITA' ? 'Receita' : 'Despesa' }}
          </span>
          <span class="tag-badge dre-badge" *ngIf="category.classificacao" style="background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1;">
            {{ getDRELabel(category.classificacao) }}
          </span>
        </div>
      </ion-card-content>
    </ion-card>
  </div>

  <!-- Mobile FAB -->
  <ion-fab vertical="bottom" horizontal="end" slot="fixed" class="ion-hide-md-up" style="margin-bottom: 16px; margin-right: 16px;">
    <ion-fab-button routerLink="/financial/categories/new" color="primary" class="custom-fab" style="--box-shadow: none;">
      <ion-icon name="add"></ion-icon>
    </ion-fab-button>
  </ion-fab>
</ion-content>