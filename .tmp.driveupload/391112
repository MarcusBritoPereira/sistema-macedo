<ion-header class="ion-no-border">
  <ion-toolbar color="primary">
    <ion-title>Rateio de Lançamento</ion-title>
    <ion-buttons slot="end">
      <ion-button (click)="cancelar()">
        <ion-icon name="close-outline" slot="icon-only"></ion-icon>
      </ion-button>
    </ion-buttons>
  </ion-toolbar>
</ion-header>

<ion-content class="ion-padding">
  <div class="transaction-info ion-margin-bottom">
    <div class="label">Lançamento:</div>
    <div class="value">{{ transaction.descricao }}</div>
    <div class="label ion-margin-top">Valor Total:</div>
    <div class="value total-val">R$ {{ transaction.valor | number:'1.2-2' }}</div>
  </div>

  <div class="rateio-list">
    <div *ngFor="let rateio of rateios; let i = index" class="rateio-item">
      <ion-card class="ion-no-margin ion-margin-bottom">
        <ion-card-content>
          <ion-row>
            <ion-col size="12" size-md="4">
              <ion-item lines="outline">
                <ion-label position="stacked">Classificação DRE</ion-label>
                <ion-select [(ngModel)]="rateio.categoria">
                  <ion-select-option *ngFor="let c of classificacoesDRE" [value]="c.value">
                    {{ c.label }}
                  </ion-select-option>
                </ion-select>
              </ion-item>
            </ion-col>
            <ion-col size="12" size-md="4">
              <ion-item lines="outline">
                <ion-label position="stacked">Subcategoria / Descrição</ion-label>
                <ion-input type="text" [(ngModel)]="rateio.subcategoria" placeholder="Ex: Advogado"></ion-input>
              </ion-item>
            </ion-col>
            <ion-col size="12" size-md="3">
              <ion-item lines="outline">
                <ion-label position="stacked">Valor (R$)</ion-label>
                <ion-input type="number" [(ngModel)]="rateio.valor" (ionChange)="calcularTotais()"></ion-input>
              </ion-item>
            </ion-col>
            <ion-col size="12" size-md="1" class="ion-text-right">
              <ion-button fill="clear" color="danger" (click)="removerRateio(i)" [disabled]="rateios.length <= 1">
                <ion-icon name="trash-outline" slot="icon-only"></ion-icon>
              </ion-button>
            </ion-col>
          </ion-row>
          <ion-row>
            <ion-col size="12">
               <ion-checkbox labelPlacement="end" [(ngModel)]="rateio.recorrente">Recorrente</ion-checkbox>
            </ion-col>
          </ion-row>
        </ion-card-content>
      </ion-card>
    </div>

    <ion-button fill="outline" expand="block" (click)="adicionarRateio()" class="ion-margin-top">
      <ion-icon name="add-outline" slot="start"></ion-icon>
      Adicionar Rateio
    </ion-button>
  </div>
</ion-content>

<ion-footer class="ion-no-border">
  <div class="summary-bar ion-padding">
    <div class="summary-item">
      <span class="label">Total Rateado:</span>
      <span class="value">R$ {{ totalRateado | number:'1.2-2' }}</span>
    </div>
    <div class="summary-item" [class.error]="diferenca !== 0">
      <span class="label">Diferença:</span>
      <span class="value">R$ {{ diferenca | number:'1.2-2' }}</span>
      <ion-button *ngIf="diferenca !== 0" fill="clear" size="small" (click)="ajustarDiferenca(rateios.length - 1)">
        Ajustar no último
      </ion-button>
    </div>
  </div>

  <ion-toolbar>
    <ion-button expand="block" (click)="salvar()" [disabled]="diferenca !== 0" class="ion-margin">
      Salvar Classificação
    </ion-button>
  </ion-toolbar>
</ion-footer>
