<ion-header [translucent]="true">
  <ion-toolbar>
    <ion-buttons slot="start">
      <ion-menu-button></ion-menu-button>
    </ion-buttons>
    <ion-title>Visão Geral</ion-title>
  </ion-toolbar>
</ion-header>

<ion-content [fullscreen]="true">
  <ion-header collapse="condense">
    <ion-toolbar>
      <ion-title size="large">Visão Geral</ion-title>
    </ion-toolbar>
  </ion-header>

  <div class="dashboard-container">
    <ion-grid>
      <ion-row>
        <ion-col size="12" size-md="6" size-lg="4">
          <ion-card routerLink="/clients">
            <ion-card-header>
              <ion-card-subtitle>Clientes</ion-card-subtitle>
              <ion-card-title>Gestão</ion-card-title>
            </ion-card-header>
            <ion-card-content>
              <ion-icon name="people" size="large"></ion-icon>
              <p>Gerenciar carteira de clientes</p>
            </ion-card-content>
          </ion-card>
        </ion-col>

        <ion-col size="12" size-md="6" size-lg="4">
          <ion-card routerLink="/users">
            <ion-card-header>
              <ion-card-subtitle>Usuários</ion-card-subtitle>
              <ion-card-title>Equipe</ion-card-title>
            </ion-card-header>
            <ion-card-content>
              <ion-icon name="person-circle" size="large"></ion-icon>
              <p>Gerenciar acessos e perfis</p>
            </ion-card-content>
          </ion-card>
        </ion-col>

        <ion-col size="12" size-md="6" size-lg="4">
          <ion-card routerLink="/financial">
            <ion-card-header>
              <ion-card-subtitle>Financeiro</ion-card-subtitle>
              <ion-card-title>Visão Geral</ion-card-title>
            </ion-card-header>
            <ion-card-content>
              <ion-icon name="cash" size="large"></ion-icon>
              <p>Fluxo de caixa e lançamentos</p>
            </ion-card-content>
          </ion-card>
        </ion-col>
      </ion-row>
    </ion-grid>
  </div>
</ion-content>