<ion-content class="stock-content"><div class="stock-page"><header class="stock-header"><div><h1>Categorias de materiais</h1><p>Classificação de estoque com vínculo financeiro quando configurado</p></div><ion-button (click)="reset()"><ion-icon name="add-outline" slot="start"></ion-icon>Nova</ion-button></header><div class="loading" *ngIf="loading"><ion-spinner name="crescent"></ion-spinner><p>Carregando categorias...</p></div><section class="form-panel" *ngIf="!loading"><div class="panel-title"><ion-icon name="folder-open-outline"></ion-icon><h2>{{ form.id ? 'Editar categoria' : 'Cadastrar categoria' }}</h2></div><div class="form-grid"><ion-item class="wide"><ion-label position="stacked">Nome *</ion-label><ion-input [(ngModel)]="form.nome"></ion-input></ion-item><ion-item class="wide"><ion-label position="stacked">Descrição</ion-label><ion-textarea [(ngModel)]="form.descricao"></ion-textarea></ion-item><ion-item><ion-label>Ativa</ion-label><ion-toggle [(ngModel)]="form.ativo"></ion-toggle></ion-item></div><div class="form-actions"><ion-button fill="outline" (click)="reset()">Limpar</ion-button><ion-button (click)="save()" [disabled]="saving || !form.nome"><ion-icon name="save-outline" slot="start"></ion-icon>Salvar</ion-button></div></section><section class="panel" *ngIf="!loading"><div class="toolbar-row"><ion-searchbar [(ngModel)]="search" placeholder="Buscar categoria" (ionInput)="load()"></ion-searchbar><ion-button fill="outline" (click)="load()"><ion-icon name="refresh-outline" slot="start"></ion-icon>Atualizar</ion-button></div><table><thead><tr><th>Nome</th><th>Descrição</th><th>Status</th></tr></thead><tbody><tr *ngFor="let item of categories" (click)="edit(item)"><td>{{ item.nome }}</td><td>{{ item.descricao || '-' }}</td><td><span class="status" [class.critical]="!item.ativo">{{ item.ativo === false ? 'INATIVA' : 'ATIVA' }}</span></td></tr></tbody></table><div class="empty" *ngIf="!categories.length">Nenhuma categoria encontrada.</div></section></div></ion-content>
