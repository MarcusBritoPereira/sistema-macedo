<ion-content class="stock-content"><div class="stock-page"><header class="stock-header"><div><h1>Saldos de estoque</h1><p>Saldo físico, reservado, disponível e valorizado por local</p></div></header><div class="loading" *ngIf="loading"><ion-spinner name="crescent"></ion-spinner><p>Carregando saldos...</p></div><section class="panel" *ngIf="!loading"><div class="toolbar-row"><ion-searchbar [(ngModel)]="search" placeholder="Buscar material ou local" (ionInput)="load()"></ion-searchbar><ion-select [(ngModel)]="situacao" interface="popover" (ionChange)="load()"><ion-select-option *ngFor="let item of situations" [value]="item">{{ item || 'Todas as situações' }}</ion-select-option></ion-select><ion-button fill="outline" (click)="load()"><ion-icon name="refresh-outline" slot="start"></ion-icon>Atualizar</ion-button></div><table><thead><tr><th>Material</th><th>Categoria</th><th>Local</th><th>Físico</th><th>Reservado</th><th>Disponível</th><th>Custo médio</th><th>Valor</th><th>Situação</th></tr></thead><tbody><tr *ngFor="let item of balances"><td>{{ item.material.codigo }} - {{ item.material.nome }}</td><td>{{ item.material.categoriaMaterial?.nome || '-' }}</td><td>{{ item.localEstoque.nome }}</td><td>{{ item.quantidade | number:'1.2-2' }}</td><td>{{ item.quantidadeReservada | number:'1.2-2' }}</td><td>{{ item.quantidadeDisponivel | number:'1.2-2' }}</td><td>{{ item.custoMedio | currency:'BRL':'symbol':'1.2-2':'pt-BR' }}</td><td>{{ item.valorTotal | currency:'BRL':'symbol':'1.2-2':'pt-BR' }}</td><td><span class="status" [class.critical]="item.situacao !== 'NORMAL'">{{ item.situacao }}</span></td></tr></tbody></table><div class="empty" *ngIf="!balances.length">Nenhum saldo encontrado.</div></section></div></ion-content>
