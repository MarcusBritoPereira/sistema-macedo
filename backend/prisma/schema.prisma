model CategoriaMaterial {
  id                    String  @id @default(uuid())
  nome                  String
  descricao             String?
  parentId              String? @map("parent_id")
  parent                CategoriaMaterial? @relation("CategoriaMaterialHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children              CategoriaMaterial[] @relation("CategoriaMaterialHierarchy")
  categoriaFinanceiraId String? @map("categoria_financeira_id")
  categoriaFinanceira   CategoriaFinanceira? @relation(fields: [categoriaFinanceiraId], references: [id], onDelete: SetNull)
  centroCustoPadraoId   String? @map("centro_custo_padrao_id")
  centroCustoPadrao     CentroCusto? @relation(fields: [centroCustoPadraoId], references: [id], onDelete: SetNull)
