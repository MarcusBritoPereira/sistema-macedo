generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. Modelo de Domínio (ERD Conceitual)

// 3. Modelo de Domínio (ERD V2 - Unificado)

model Usuario {
  id                 String   @id @default(uuid())
  nome               String
  email              String   @unique
  senha              String
  ativo              Boolean  @default(true)
  precisaTrocarSenha Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  perfilId String
  perfil   Perfil @relation(fields: [perfilId], references: [id])

  logs                    LogAuditoria[]
  centrosCustoResponsavel CentroCusto[]  @relation("CentroCustoResponsavel")

  @@map("usuarios")
}

model Perfil {
  id         String    @id @default(uuid())
  nome       String    @unique // ex: ADMIN, FINANCEIRO, GESTOR
  descricao  String?
  permissoes Json? // Armazenar permissões como JSON para flexibilidade
  usuarios   Usuario[]

  @@index([nome], map: "idx_perfis_nome")
  @@map("perfis")
}

model Cliente {
  id                String  @id @default(uuid())
  // 1. Dados Cadastrais (PJ)
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String? @unique
  inscricaoEstadual String?
  cpf               String? @unique
  email             String?
  telefone          String?
  endereco          String? // Endereço completo

  // 2. Representante Legal
  representanteNome     String?
  representanteCpf      String?
  representanteCargo    String?
  representanteEmail    String?
  representanteTelefone String?

  // 3. Responsável Financeiro
  financeiroNome               String?
  financeiroEmail              String?
  financeiroWhatsapp           String?
  financeiroPreferenciaContato String? // Whatsapp, E-mail, Telefone

  // 4. Dados Operacionais
  redesSociais   Json? // { instagram: "@...", linkedin: "..." }
  usuariosAdmins String? // Lista de nomes/emails
  linksUteis     Json? // { drive: "...", trello: "..." }
  nicho          String?
  qtdConteudo    String?
  consultora     String?

  // 5. Dados Fiscais
  emissaoNf  Boolean @default(false)
  emailNf    String?
  obsFiscais String?

  // 6. Dados Jurídicos
  foro             String?
  lgpdAceito       Boolean @default(false)
  aceiteEletronico Boolean @default(false)

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contratos   Contrato[]
  contatos    Contato[]
  leads       Lead[]
  lancamentos LancamentoFinanceiro[]
  obras       Obra[]

  @@map("clientes")
}

model Contato {
  id        String  @id @default(uuid())
  nome      String
  email     String?
  telefone  String?
  cargo     String?
  principal Boolean @default(false)

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  @@map("contatos")
}

model Contrato {
  id        String  @id @default(uuid())
  descricao String?

  // Dados do Contrato (Regra de Negócio)
  tipo               String? // RECORRENTE, PROJETO
  valorMensal        Decimal @db.Decimal(10, 2)
  quantidadeParcelas Int?
  diaVencimento      Int?
  formaPagamento     String? // Boleto, Pix, Cartão
  multaJuros         String? // Descrição de multa/juros

  dataInicio DateTime
  dataFim    DateTime?
  ativo      Boolean        @default(true)
  status     StatusContrato @default(ATIVO)

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // O Contrato não gera "ContaReceber" direta, mas "LancamentoFinanceiro"
  lancamentos LancamentoFinanceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contratos")
}

enum StatusContrato {
  ATIVO
  VENCIDO
  CANCELADO
  RENOVADO
}

// --- V2: Lançamento Financeiro Unificado ---

model LancamentoFinanceiro {
  id              String    @id @default(uuid())
  descricao       String
  valor           Decimal   @db.Decimal(10, 2)
  dataVencimento  DateTime
  dataPagamento   DateTime?
  dataCompetencia DateTime? // Nova data de competência (opcional, pode ser diferente de pagamento/vencimento)

  tipo   TipoLancamento // RECEITA, DESPESA
  status StatusLancamento @default(PREVISTO)

  observacoes    String?
  urlComprovante String?

  // Relacionamentos V2
  contaBancariaId String?
  contaBancaria   ContaBancaria? @relation(fields: [contaBancariaId], references: [id])

  categoriaId String?
  categoria   CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])

  centroCustoId String?
  centroCusto   CentroCusto? @relation(fields: [centroCustoId], references: [id])

  // Origem do Lançamento
  contratoId String?
  contrato   Contrato? @relation(fields: [contratoId], references: [id])

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])

  fornecedorNome String? // Mantendo para compatibilidade ou uso simples se necessário

  obraId String?
  obra   Obra?   @relation(fields: [obraId], references: [id])

  tipoLancamento TipoClassificacaoLancamento? @map("tipo_lancamento")
  tipoCusto      TipoCustoLancamento?         @map("tipo_custo")
  categoriaCusto String?                      @map("categoria_custo")

  recurrenciaId String?
  recurrencia   Recurrencia? @relation(fields: [recurrenciaId], references: [id])

  recorrente       Boolean            @default(false)
  rateios          RateioLancamento[]
  rateiosHistorico RateioHistorico[]

  conciliacoes ConciliacaoBancaria[]
  parcelaObra  ParcelaObra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataCompetencia], map: "idx_lancamentos_competencia")
  @@index([tipo, status, dataVencimento], map: "idx_lancamento_tipo_status_venc")
  @@index([contaBancariaId, status, dataVencimento], map: "idx_lancamento_conta_status_venc")
  @@index([categoriaId, dataCompetencia], map: "idx_lancamento_categoria_comp")
  @@index([clienteId, dataVencimento], map: "idx_lancamento_cliente_venc")
  @@index([fornecedorId, dataVencimento], map: "idx_lancamento_fornecedor_venc")
  @@index([tipo, status, dataPagamento], map: "idx_lancamento_tipo_status_pag")
  @@index([centroCustoId], map: "idx_lancamento_centro_custo")
  @@map("lancamentos_financeiros")
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum TipoClassificacaoLancamento {
  OBRA
  POS_OBRA
  ADMINISTRATIVO
  ESCRITORIO
}

enum TipoCustoLancamento {
  MATERIAL
  MAO_DE_OBRA
  SERVICO
  EQUIPAMENTO
  OUTROS
}

enum StatusLancamento {
  PREVISTO
  REALIZADO
  CONCILIADO
  CANCELADO
}

// --- V2: Bancário & Conciliação ---

model ContaBancaria {
  id           String  @id @default(uuid())
  nome         String // Apelido: "Inter Principal"
  banco        String // "Banco Inter"
  agencia      String?
  conta        String?
  codigoBanco  String?
  saldoInicial Decimal @default(0) @db.Decimal(10, 2)

  lancamentos LancamentoFinanceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integracao  IntegracaoBancaria?
  importacoes ImportacaoBancaria[]

  @@map("contas_bancarias")
}

model IntegracaoBancaria {
  id           String  @id @default(uuid())
  banco        String // "INTER"
  apiKey       String? // Stored credential (should be encrypted in real prod)
  clientId     String?
  clientSecret String?
  crtFile      String? // Path to certificate file if needed
  keyFile      String? // Path to key file if needed

  status              StatusIntegracao @default(DISCONNECTED)
  lastSync            DateTime?
  dataInicioAutomacao DateTime?        @map("data_inicio_automacao")

  contaBancariaId String        @unique
  contaBancaria   ContaBancaria @relation(fields: [contaBancariaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integracoes_bancarias")
}

enum StatusIntegracao {
  CONNECTED
  DISCONNECTED
  ERROR
}

model ExtratoBancario {
  id        String        @id @default(uuid())
  data      DateTime
  descricao String
  valor     Decimal       @db.Decimal(10, 2)
  tipo      TipoTransacao // CREDIT, DEBIT
  hash      String        @unique // Para evitar duplicatas

  // V2: Campos para importação robusta (CSV/OFX)
  fitid           String? // ID único do OFX ou gerado
  sourceType      SourceType @default(CSV)
  balance         Decimal?   @db.Decimal(10, 2)
  matchConfidence Int? // 0-100
  currency        String     @default("BRL")
  importedAt      DateTime   @default(now())

  // Relacionamento com log de importação
  importacaoId String?
  importacao   ImportacaoBancaria? @relation(fields: [importacaoId], references: [id])

  // V2: Status de conciliação simples no extrato, detalhe na tabela pivot
  conciliado Boolean @default(false)

  conciliacoes ConciliacaoBancaria[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([data, conciliado], map: "idx_extrato_data_conciliado")
  @@index([importacaoId, conciliado], map: "idx_extrato_importacao_conciliado")
  @@index([tipo, conciliado], map: "idx_extrato_tipo_conciliado")
  @@index([valor, data], map: "idx_extrato_valor_data")
  @@map("extratos_bancarios")
}

enum SourceType {
  CSV
  OFX
  MANUAL
}

model ImportacaoBancaria {
  id       String           @id @default(uuid())
  filename String
  fileType SourceType
  status   StatusImportacao @default(PROCESSING)
  log      String? // JSON ou Texto com erros

  importedAt DateTime @default(now())

  contaBancariaId String
  contaBancaria   ContaBancaria @relation(fields: [contaBancariaId], references: [id])

  extratos ExtratoBancario[]

  @@map("importacoes_bancarias")
}

enum StatusImportacao {
  PROCESSING
  COMPLETED
  ERROR
  PARTIAL
}

model ConciliacaoBancaria {
  id              String   @id @default(uuid())
  dataConciliacao DateTime @default(now())

  type TipoConciliacao @default(SYSTEM_MATCH)

  lancamentoFinanceiroId String               @unique // 1 para 1 geralmente
  lancamentoFinanceiro   LancamentoFinanceiro @relation(fields: [lancamentoFinanceiroId], references: [id])

  extratoBancarioId String          @unique
  extratoBancario   ExtratoBancario @relation(fields: [extratoBancarioId], references: [id])

  @@index([lancamentoFinanceiroId], map: "idx_conciliacao_lancamento")
  @@index([extratoBancarioId], map: "idx_conciliacao_extrato")
  @@map("conciliacoes_bancarias")
}

enum TipoConciliacao {
  SYSTEM_MATCH
  MANUAL_CREATE
  MANUAL_LINK
}

enum TipoTransacao {
  CREDIT
  DEBIT
}

// --- V2: Categoria Financeira Hierárquica ---

model CategoriaFinanceira {
  id            String            @id @default(uuid())
  nome          String
  tipo          TipoCategoria // RECEITA ou DESPESA
  descricao     String?
  classificacao ClassificacaoDRE?

  parentId String?
  parent   CategoriaFinanceira?  @relation("CategoriaHierarchy", fields: [parentId], references: [id])
  children CategoriaFinanceira[] @relation("CategoriaHierarchy")

  lancamentos  LancamentoFinanceiro[]
  rateios      RateioLancamento[]
  regras       RegraClassificacao[]
  centrosCusto CentroCusto[]          @relation("CentroCustoPlanoConta")

  @@map("categorias_financeiras")
}

model RateioLancamento {
  id           String  @id @default(uuid())
  valor        Decimal @db.Decimal(10, 2)
  recorrente   Boolean @default(false)
  observacao   String?
  categoria    String // ClassificacaoDRE key
  subcategoria String? // nome da subcategoria livre

  lancamentoId String
  lancamento   LancamentoFinanceiro @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)

  categoriaFinanceiraId String?
  categoriaFinanceira   CategoriaFinanceira? @relation(fields: [categoriaFinanceiraId], references: [id])

  obraId String?
  obra   Obra?   @relation(fields: [obraId], references: [id], onDelete: SetNull)

  centroCustoId String?
  centroCusto   CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)

  tipoDestino    TipoDestinoRateio?   @map("tipo_destino")
  tipoCusto      TipoCustoLancamento? @map("tipo_custo")
  categoriaCusto String?              @map("categoria_custo")
  descricaoItem  String?              @map("descricao_item")
  quantidade     Decimal?             @db.Decimal(12, 3)
  valorUnitario  Decimal?             @map("valor_unitario") @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  historicos RateioHistorico[]

  @@index([obraId])
  @@index([centroCustoId])
  @@map("rateios_lancamento")
}

enum TipoDestinoRateio {
  OBRA
  CENTRO_CUSTO
}

model RateioHistorico {
  id              String   @id @default(uuid())
  rateioId        String?
  lancamentoId    String
  valorAntigo     Decimal? @db.Decimal(10, 2)
  valorNovo       Decimal? @db.Decimal(10, 2)
  categoriaAntiga String?
  categoriaNova   String?
  dataEdicao      DateTime @default(now())
  usuario         String

  rateio     RateioLancamento?    @relation(fields: [rateioId], references: [id], onDelete: SetNull)
  lancamento LancamentoFinanceiro @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)

  @@map("rateios_historico")
}

model DreCache {
  id        String   @id @default(uuid())
  chave     String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dre_cache")
}

enum ClassificacaoDRE {
  RECEITA_RECORRENTE
  RECEITA_NAO_RECORRENTE
  DEDUCOES_RECEITA
  CUSTO_SERVICOS_PRESTADOS
  DESPESA_ADMINISTRATIVA
  DESPESA_COMERCIAL
  DESPESA_ESTRUTURAL
  DESPESA_SOCIOS
  DESPESA_FINANCEIRA
  RECEITA_FINANCEIRA
  IMPOSTOS_LUCRO
  INVESTIMENTOS
  OUTROS
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum TipoCentroCusto {
  OPERACIONAL
  ADMINISTRATIVO
  COMERCIAL
  FINANCEIRO
  ENGENHARIA
  SUPRIMENTOS
  RH
  POS_OBRA
  EQUIPAMENTOS
}

enum CategoriaFinanceiraCentro {
  RECEITA
  CUSTO
  DESPESA
  INVESTIMENTO
}

model CentroCusto {
  id                  String                     @id @default(uuid())
  nome                String
  codigo              String?                    @unique
  descricao           String?
  tipo                TipoCentroCusto?
  categoriaFinanceira CategoriaFinanceiraCentro? @map("categoria_financeira")

  // Hierarquia (Auto-relacionamento)
  parentId String?       @map("parent_id")
  parent   CentroCusto?  @relation("Hierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children CentroCusto[] @relation("Hierarchy")

  // Vinculação com Obra e Etapas
  obraId  String? @map("obra_id")
  obra    Obra?   @relation("CentroCustoObra", fields: [obraId], references: [id], onDelete: SetNull)
  etapaId String? @map("etapa_id") // 'FUNDACAO' | 'ESTRUTURA' | 'ACABAMENTO' | 'INSTALACOES' | 'FACHADA' etc.

  // Controle Financeiro
  ativo               Boolean  @default(true)
  aceitaLancamento    Boolean  @default(true) @map("aceita_lancamento")
  orcamentoPrevisto   Decimal? @map("orcamento_previsto") @db.Decimal(15, 2)
  limiteMaximo        Decimal? @map("limite_maximo") @db.Decimal(15, 2)
  aprovacaoNecessaria Boolean  @default(false) @map("aprovacao_necessaria")

  responsavelId String?  @map("responsavel_id")
  responsavel   Usuario? @relation("CentroCustoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  // Integrações
  planoContaId    String?              @map("plano_conta_id")
  planoConta      CategoriaFinanceira? @relation("CentroCustoPlanoConta", fields: [planoContaId], references: [id], onDelete: SetNull)
  categoriaCompra String?              @map("categoria_compra") // 'Material' | 'Servico' | 'Equipamento'
  contaContabil   String?              @map("conta_contabil")

  // Controle de Produção
  unidadeMedida String?  @map("unidade_medida") // m², m³, tonelada, un
  metaFisica    Decimal? @map("meta_fisica") @db.Decimal(15, 2)

  // Metadados Inteligentes
  tags String? @map("tags")
  cor  String? @map("cor")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações existentes mantidas
  rateios     RateioLancamento[]
  lancamentos LancamentoFinanceiro[]
  regras      RegraClassificacao[]
  obras       Obra[]                 @relation("ObraMainCentroCusto")

  @@map("centros_custo")
}

model FinancialBudget {
  id          String  @id @default(uuid())
  mes         Int
  ano         Int
  receitaMeta Decimal @db.Decimal(10, 2)
  despesaMeta Decimal @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt

  @@unique([mes, ano])
  @@map("orcamentos_financeiros")
}

// Removed: Pagamento Model (Redundant with LancamentoFinanceiro REALIZADO)

model Lead {
  id     String  @id @default(uuid())
  nome   String
  email  String?
  status String // Novo, Qualificado, Perdido, Cliente

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id]) // Se virou cliente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model ParametroFiscal {
  id        String  @id @default(uuid())
  nome      String  @unique // ex: ALIQUOTA_ISS
  valor     String
  descricao String?

  @@map("parametros_fiscais")
}

model LogAuditoria {
  id          String   @id @default(uuid())
  data        DateTime @default(now())
  acao        String
  tabela      String?
  registroId  String?
  valorAntigo String?
  valorNovo   String?
  motivo      String

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@map("logs_auditoria")
}

model Fornecedor {
  id           String  @id @default(uuid())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String? @unique
  email        String?
  telefone     String?

  // Categoria padrão para agilizar lançamentos
  categoriaDefaultId String?

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lancamentos LancamentoFinanceiro[]

  @@map("fornecedores")
}

model Recurrencia {
  id            String                @id @default(uuid())
  frequencia    FrequenciaRecurrencia
  dataInicio    DateTime
  dataFim       DateTime?
  diaVencimento Int? // Para mensal
  ativo         Boolean               @default(true)

  lancamentos LancamentoFinanceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurrencias")
}

enum FrequenciaRecurrencia {
  MENSAL
  SEMANAL
  ANUAL
  DIARIO
}

model RegraClassificacao {
  id             String               @id @default(uuid())
  padraoTexto    String               @unique
  categoriaId    String?
  categoria      CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  subcategoriaId String?
  centroCustoId  String?
  centroCusto    CentroCusto?         @relation(fields: [centroCustoId], references: [id])
  prioridade     Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("regras_classificacao")
}

// --- V2: Gestão de Obras ---

model Obra {
  id                String     @id @default(uuid())
  nome              String
  descricao         String?
  dataInicio        DateTime?
  dataPrevisaoFim   DateTime?
  dataConclusao     DateTime?
  status            StatusObra @default(PLANEJAMENTO)
  orcamentoPrevisto Decimal?   @db.Decimal(10, 2)
  endereco          String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  centroCustoId   String?
  centroCusto     CentroCusto?  @relation("ObraMainCentroCusto", fields: [centroCustoId], references: [id])
  centrosCustoRel CentroCusto[] @relation("CentroCustoObra")

  lancamentos LancamentoFinanceiro[]
  rateios     RateioLancamento[]
  parcelas    ParcelaObra[]

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("obras")
}

enum StatusObra {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADA
  CONCLUIDA
  CANCELADA
}

model ParcelaObra {
  id             String        @id @default(uuid())
  obraId         String
  obra           Obra          @relation(fields: [obraId], references: [id], onDelete: Cascade)
  porcentagem    Decimal       @db.Decimal(5, 2)
  valor          Decimal       @db.Decimal(10, 2)
  dataVencimento DateTime
  descricao      String?
  status         StatusParcela @default(PREVISTO)

  transacaoId String?               @unique
  transacao   LancamentoFinanceiro? @relation(fields: [transacaoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([obraId])
  @@index([status])
  @@map("parcelas_obra")
}

enum StatusParcela {
  PREVISTO
  RECEBIDO
  ATRASADO
}
