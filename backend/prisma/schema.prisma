  aprovadoPor    Usuario? @relation("OrcamentoMaterialAprovadoPor", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  itens          ItemOrcamentoMaterialObra[]

  @@unique([obraId, versao], map: "uq_orcamentos_material_obra_versao")
  @@index([status], map: "idx_orcamentos_material_status")
  @@map("orcamentos_material_obra")
}

model ItemOrcamentoMaterialObra {
  id                  String @id @default(uuid())
  orcamentoId         String @map("orcamento_id")
  orcamento           OrcamentoMaterialObra @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  materialId          String @map("material_id")
  material            Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  categoriaMaterialId String? @map("categoria_material_id")
  categoriaMaterial   CategoriaMaterial? @relation(fields: [categoriaMaterialId], references: [id], onDelete: SetNull)
  quantidadeOrcada    Decimal @map("quantidade_orcada") @db.Decimal(15, 3)
  custoUnitarioOrcado Decimal @map("custo_unitario_orcado") @db.Decimal(15, 4)
  custoTotalOrcado    Decimal @map("custo_total_orcado") @db.Decimal(15, 2)
  etapaObra           String? @map("etapa_obra")
  centroCustoId       String? @map("centro_custo_id")
  centroCusto         CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  observacao          String?

  @@unique([orcamentoId, materialId, etapaObra], map: "uq_itens_orcamento_material_etapa")
  @@index([materialId], map: "idx_itens_orcamento_material")
  @@index([categoriaMaterialId], map: "idx_itens_orcamento_categoria")
  @@index([centroCustoId], map: "idx_itens_orcamento_cc")
  @@map("itens_orcamento_material_obra")
}

model ApropriacaoCustoEstoque {
  id                String @id @default(uuid())
  movimentoEstoqueId String @unique @map("movimento_estoque_id")
  movimentoEstoque MovimentoEstoque @relation(fields: [movimentoEstoqueId], references: [id], onDelete: Restrict)
  obraId            String @map("obra_id")
  obra              Obra @relation(fields: [obraId], references: [id], onDelete: Restrict)
  centroCustoId     String? @map("centro_custo_id")
  centroCusto       CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  categoriaId       String? @map("categoria_id")
  categoria         CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  materialId        String @map("material_id")
  material          Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  quantidade        Decimal @db.Decimal(15, 3)
  custoUnitario     Decimal @map("custo_unitario") @db.Decimal(15, 4)
  custoTotal        Decimal @map("custo_total") @db.Decimal(15, 2)
  dataCompetencia   DateTime @map("data_competencia")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([obraId, dataCompetencia], map: "idx_apropriacoes_estoque_obra_data")
  @@index([centroCustoId], map: "idx_apropriacoes_estoque_cc")
  @@index([categoriaId], map: "idx_apropriacoes_estoque_categoria")
  @@index([materialId], map: "idx_apropriacoes_estoque_material")
  @@map("apropriacoes_custo_estoque")
}
