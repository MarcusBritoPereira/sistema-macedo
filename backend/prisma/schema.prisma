  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  materiais             Material[]
  itensOrcamento        ItemOrcamentoMaterialObra[]

  @@index([parentId], map: "idx_categorias_material_parent")
  @@index([categoriaFinanceiraId], map: "idx_categorias_material_financeira")
  @@index([centroCustoPadraoId], map: "idx_categorias_material_cc_padrao")
  @@map("categorias_material")
}

model Material {
  id                  String @id @default(uuid())
  codigo              String @unique
  nome                String
  descricao           String?
  categoriaMaterialId String @map("categoria_material_id")
  categoriaMaterial   CategoriaMaterial @relation(fields: [categoriaMaterialId], references: [id], onDelete: Restrict)
  unidade             UnidadeMedidaMaterial
  codigoBarras        String? @unique @map("codigo_barras")
  referenciaFornecedor String? @map("referencia_fornecedor")
  marca               String?
  fabricante          String?
  estoqueMinimo       Decimal @default(0) @map("estoque_minimo") @db.Decimal(15, 3)
  estoqueMaximo       Decimal? @map("estoque_maximo") @db.Decimal(15, 3)
  pontoReposicao      Decimal @default(0) @map("ponto_reposicao") @db.Decimal(15, 3)
  custoPadrao         Decimal? @map("custo_padrao") @db.Decimal(15, 4)
  ultimoCusto         Decimal? @map("ultimo_custo") @db.Decimal(15, 4)
  custoMedio          Decimal @default(0) @map("custo_medio") @db.Decimal(15, 4)
  permiteFracionado   Boolean @default(false) @map("permite_fracionado")
  ativo               Boolean @default(true)
  observacoes         String?
  criadoPorId         String? @map("criado_por_id")
  criadoPor           Usuario? @relation("MaterialCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  saldos              SaldoEstoque[]
  movimentos          MovimentoEstoque[]
  itensDocumento      ItemDocumentoEstoque[]
  itensInventario     ItemInventarioEstoque[]
  reservas            ReservaEstoque[]
  itensSolicitacao    ItemSolicitacaoMaterial[]
  itensOrcamento      ItemOrcamentoMaterialObra[]
  apropriacoes        ApropriacaoCustoEstoque[]

  @@index([categoriaMaterialId], map: "idx_materiais_categoria")
  @@index([ativo], map: "idx_materiais_ativo")
  @@map("materiais")
}

model LocalEstoque {
  id                   String @id @default(uuid())
  nome                 String
  codigo               String @unique
  tipo                 TipoLocalEstoque
  obraId               String? @map("obra_id")
  obra                 Obra? @relation(fields: [obraId], references: [id], onDelete: SetNull)
  responsavelId        String? @map("responsavel_id")
  responsavel          Usuario? @relation("LocalEstoqueResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  endereco             String?
  permiteSaldoNegativo Boolean @default(false) @map("permite_saldo_negativo")
  ativo                Boolean @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  saldos               SaldoEstoque[]
  movimentosOrigem     MovimentoEstoque[] @relation("MovimentoEstoqueOrigem")
  movimentosDestino    MovimentoEstoque[] @relation("MovimentoEstoqueDestino")
  documentosOrigem     DocumentoEstoque[] @relation("DocumentoEstoqueOrigem")
  documentosDestino    DocumentoEstoque[] @relation("DocumentoEstoqueDestino")
  inventarios          InventarioEstoque[]
  reservas             ReservaEstoque[]
  solicitacoesDestino  SolicitacaoMaterial[]

  @@index([obraId], map: "idx_locais_estoque_obra")
  @@index([tipo], map: "idx_locais_estoque_tipo")
  @@index([ativo], map: "idx_locais_estoque_ativo")
  @@map("locais_estoque")
}

model SaldoEstoque {
  id                  String @id @default(uuid())
  materialId          String @map("material_id")
  material            Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  localEstoqueId      String @map("local_estoque_id")
  localEstoque        LocalEstoque @relation(fields: [localEstoqueId], references: [id], onDelete: Restrict)
  quantidade          Decimal @default(0) @db.Decimal(15, 3)
  quantidadeReservada Decimal @default(0) @map("quantidade_reservada") @db.Decimal(15, 3)
  custoMedio          Decimal @default(0) @map("custo_medio") @db.Decimal(15, 4)
  valorTotal          Decimal @default(0) @map("valor_total") @db.Decimal(15, 2)
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([materialId, localEstoqueId], map: "uq_saldos_material_local")
  @@index([materialId], map: "idx_saldos_material")
  @@index([localEstoqueId], map: "idx_saldos_local")
  @@map("saldos_estoque")
}

model MovimentoEstoque {
  id                    String @id @default(uuid())
  numero                String @unique
  tipo                  TipoMovimentoEstoque
  status                StatusMovimentoEstoque @default(EFETIVADO)
  materialId            String @map("material_id")
  material              Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  localOrigemId         String? @map("local_origem_id")
  localOrigem           LocalEstoque? @relation("MovimentoEstoqueOrigem", fields: [localOrigemId], references: [id], onDelete: Restrict)
  localDestinoId        String? @map("local_destino_id")
  localDestino          LocalEstoque? @relation("MovimentoEstoqueDestino", fields: [localDestinoId], references: [id], onDelete: Restrict)
  obraId                String? @map("obra_id")
  obra                  Obra? @relation(fields: [obraId], references: [id], onDelete: SetNull)
  fornecedorId          String? @map("fornecedor_id")
  fornecedor            Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  quantidade            Decimal @db.Decimal(15, 3)
  unidade               UnidadeMedidaMaterial
  custoUnitario         Decimal @default(0) @map("custo_unitario") @db.Decimal(15, 4)
  custoTotal            Decimal @default(0) @map("custo_total") @db.Decimal(15, 2)
  saldoAnteriorOrigem   Decimal? @map("saldo_anterior_origem") @db.Decimal(15, 3)
  saldoPosteriorOrigem  Decimal? @map("saldo_posterior_origem") @db.Decimal(15, 3)
  saldoAnteriorDestino  Decimal? @map("saldo_anterior_destino") @db.Decimal(15, 3)
  saldoPosteriorDestino Decimal? @map("saldo_posterior_destino") @db.Decimal(15, 3)
  dataMovimento         DateTime @default(now()) @map("data_movimento")
  documentoTipo         String? @map("documento_tipo")
  documentoNumero       String? @map("documento_numero")
  notaFiscalNumero      String? @map("nota_fiscal_numero")
  notaFiscalChave       String? @map("nota_fiscal_chave")
  observacao            String?
  movimentoRelacionadoId String? @map("movimento_relacionado_id")
  movimentoRelacionado  MovimentoEstoque? @relation("MovimentoEstoqueRelacionado", fields: [movimentoRelacionadoId], references: [id], onDelete: SetNull)
  movimentosRelacionados MovimentoEstoque[] @relation("MovimentoEstoqueRelacionado")
  documentoEstoqueId    String? @map("documento_estoque_id")
  documentoEstoque      DocumentoEstoque? @relation(fields: [documentoEstoqueId], references: [id], onDelete: SetNull)
  transacaoFinanceiraId String? @map("transacao_financeira_id")
  transacaoFinanceira   LancamentoFinanceiro? @relation(fields: [transacaoFinanceiraId], references: [id], onDelete: SetNull)
  solicitadoPorId       String? @map("solicitado_por_id")
  solicitadoPor         Usuario? @relation("MovimentoEstoqueSolicitadoPor", fields: [solicitadoPorId], references: [id], onDelete: SetNull)
  aprovadoPorId         String? @map("aprovado_por_id")
  aprovadoPor           Usuario? @relation("MovimentoEstoqueAprovadoPor", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  registradoPorId       String? @map("registrado_por_id")
  registradoPor         Usuario? @relation("MovimentoEstoqueRegistradoPor", fields: [registradoPorId], references: [id], onDelete: SetNull)
  canceladoPorId        String? @map("cancelado_por_id")
  canceladoPor          Usuario? @relation("MovimentoEstoqueCanceladoPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  motivoCancelamento    String? @map("motivo_cancelamento")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  apropriacaoCusto      ApropriacaoCustoEstoque?

  @@index([materialId], map: "idx_movimentos_estoque_material")
  @@index([localOrigemId], map: "idx_movimentos_estoque_origem")
  @@index([localDestinoId], map: "idx_movimentos_estoque_destino")
  @@index([obraId, dataMovimento], map: "idx_movimentos_estoque_obra_data")
  @@index([tipo], map: "idx_movimentos_estoque_tipo")
  @@index([status, dataMovimento], map: "idx_movimentos_estoque_status_data")
  @@index([fornecedorId], map: "idx_movimentos_estoque_fornecedor")
  @@index([documentoNumero], map: "idx_movimentos_estoque_documento")
  @@index([notaFiscalNumero], map: "idx_movimentos_estoque_nf")
  @@index([localDestinoId, dataMovimento], map: "idx_movimentos_estoque_destino_data")
  @@index([localOrigemId, dataMovimento], map: "idx_movimentos_estoque_origem_data")
  @@map("movimentos_estoque")
}

model DocumentoEstoque {
